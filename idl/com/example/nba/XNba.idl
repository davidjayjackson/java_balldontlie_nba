#include <com/sun/star/uno/XInterface.idl>

module com { module example { module nba {

    /** Add-in interface exposing balldontlie NBA data as LibreOffice Calc
        worksheet functions.

        Cell functions in this add-in never block on network I/O and never
        throw. Every function resolves against a shared, TTL'd, background-
        refreshed cache and returns one of:
        <ul>
          <li>the requested value (fresh or last-known-good cached data), or</li>
          <li>"#LOADING" - first request for this data; a background fetch
              was just started. Recalculate (F9 / Ctrl+Shift+F9) once it
              completes.</li>
          <li>"#NO_API_KEY" - no balldontlie API key could be resolved. See
              NBA_LASTERROR and the README for the three key-resolution
              mechanisms.</li>
          <li>"#NOT_FOUND" - the request was well-formed and reached the API,
              but no matching data exists (unknown team, empty search, etc).</li>
          <li>"#ERR" - the fetch failed persistently (network, rate limit
              exhausted, bad response). Call NBA_LASTERROR() for detail.</li>
        </ul>

        Table-returning functions return a matrix (sequence of sequences);
        LibreOffice has no dynamic spill, so select the output range and
        enter the formula as an array formula (Ctrl+Shift+Enter) to see every
        row. A plain single-cell entry shows only the top-left cell. */
    interface XNba
    {
        interface ::com::sun::star::uno::XInterface;

        /** Resolve a team name or abbreviation to its numeric team id.

            @param nameOrAbbrev team full name, city, name, or abbreviation
                (case-insensitive), e.g. "Lakers" or "LAL".
            @returns the numeric team id, or a sentinel string.
         */
        any nbaTeamId( [in] string nameOrAbbrev );

        /** List every NBA team.

            @returns a matrix of rows: id, abbreviation, city, conference,
                division, full_name, name.
         */
        sequence< sequence< any > > nbaTeams();

        /** Search players by name.

            @param name a full or partial player name.
            @returns a matrix of rows: id, first_name, last_name, position,
                team abbreviation. Up to 100 matches.
         */
        sequence< sequence< any > > nbaPlayerSearch( [in] string name );

        /** Resolve a player's full name to their numeric player id (best
            match: the first result of a name search).

            @param fullName player name to search for, e.g. "LeBron James".
            @returns the numeric player id, or a sentinel string.
         */
        any nbaPlayerId( [in] string fullName );

        /** List games for a date or a season.

            @param dateOrSeason either an ISO date "YYYY-MM-DD" (games on
                that date) or a 4-digit season year "YYYY" (games in that
                season).
            @param teamId optional. A numeric team id (from NBA_TEAMID) to
                filter to. Only honored in season mode. Declared as
                <em>any</em> so it may be omitted.
            @returns a matrix of rows: date, home_team, home_score,
                away_team, away_score, status.
         */
        sequence< sequence< any > > nbaGames(
            [in] string dateOrSeason,
            [in] any teamId );

        /** The most recent (or Nth most recent) result for a team in a
            season, as a formatted string.

            @param season 4-digit season year, e.g. "2024".
            @param abbrev team abbreviation, e.g. "LAL".
            @param nth optional. 1 = most recent game (default), 2 = second
                most recent, etc. Declared as <em>any</em> so it may be
                omitted.
            @returns a result string, e.g.
                "2024-04-10 LAL 112 - 108 BOS (W)", or a sentinel string.
         */
        any nbaScore(
            [in] string season,
            [in] string abbrev,
            [in] any nth );

        /** League standings for a season.

            @param season 4-digit season year, e.g. "2024".
            @param conference optional. "East" or "West" to filter.
                Declared as <em>any</em> so it may be omitted.
            @returns a matrix of rows: conference, division, team
                (abbreviation), wins, losses, win_pct, conference_rank.
         */
        sequence< sequence< any > > nbaStandings(
            [in] string season,
            [in] any conference );

        /** A team's conference rank in a season.

            @param season 4-digit season year, e.g. "2024".
            @param abbrev team abbreviation, e.g. "LAL".
            @returns the numeric conference rank, or a sentinel string.
         */
        any nbaTeamRank(
            [in] string season,
            [in] string abbrev );

        /** A player's season-average statistic.

            @param season 4-digit season year, e.g. "2024".
            @param id numeric player id (from NBA_PLAYERID).
            @param statKey one of: pts, reb, ast, stl, blk, turnover, pf,
                fgm, fga, fg_pct, fg3m, fg3a, fg3_pct, ftm, fta, ft_pct,
                oreb, dreb, min. Averaged across the player's games that
                season (simple mean, not attempt-weighted for percentages).
            @returns the numeric season average, or a sentinel string.
         */
        any nbaPlayerStat(
            [in] string season,
            [in] any id,
            [in] string statKey );

        /** Per-player box score for a single game.

            @param gameId numeric game id.
            @returns a matrix of rows: player, team, min, pts, reb, ast,
                stl, blk, fg_pct, fg3_pct, ft_pct.
         */
        sequence< sequence< any > > nbaBoxScore( [in] any gameId );

        /** The most recent fetch error message, for diagnostics.

            @returns the last error message, or an empty string if none.
         */
        string nbaLastError();

        /** Clear every cached response.

            @returns the number of cache entries cleared.
         */
        double nbaCacheClear();
    };

}; }; };
